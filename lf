          "node": {
            "display_name": "Chroma Part Number Search",
            "description": "Searches all ChromaDB collections for a part number and returns the model name (collection name).",
            "documentation": "",
            "base_classes": [
              "Message"
            ],
            "template": {
              "_type": "CustomComponent",
              "code": {
                "name": "code",
                "display_name": "Code",
                "type": "code",
                "value": "from langflow.custom import Component\nfrom langflow.io import MessageInput, Output, StrInput\nfrom langflow.schema.message import Message\nimport chromadb\n\n\nclass ChromaPartNumberSearch(Component):\n    \"\"\"\n    Searches every collection in a ChromaDB server (localhost:8000 by default).\n    Collection names are treated as model names. Returns the model whose\n    collection contains the supplied part number.\n\n    Search strategy (attempted in order for each collection):\n      1. Get by document ID  \u2013 fastest; works when part numbers are stored as IDs.\n      2. Metadata filter     \u2013 works when part_number is a metadata field.\n      3. Document text match \u2013 fallback; works when the part number appears\n                               anywhere inside the document text.\n    \"\"\"\n\n    display_name: str = \"Chroma Part Number Search\"\n    description: str = \"Find the model (collection) that contains the given part number.\"\n    icon: str = \"database\"\n\n    inputs = [\n        MessageInput(\n            name=\"part_number_message\",\n            display_name=\"Part Number (Message)\",\n            info=\"Connect the Chat Input Message here.\",\n        ),\n        StrInput(\n            name=\"chroma_host\",\n            display_name=\"Chroma Host\",\n            value=\"localhost\",\n            info=\"Hostname of the ChromaDB server.\",\n            advanced=True,\n        ),\n        StrInput(\n            name=\"chroma_port\",\n            display_name=\"Chroma Port\",\n            value=\"8000\",\n            info=\"Port of the ChromaDB server.\",\n            advanced=True,\n        ),\n        StrInput(\n            name=\"metadata_key\",\n            display_name=\"Part Number Metadata Key\",\n            value=\"part_number\",\n            info=\"The metadata field name used to store part numbers (used in fallback search).\",\n            advanced=True,\n        ),\n    ]\n\n    outputs = [\n        Output(\n            display_name=\"Result Message\",\n            name=\"result_message\",\n            method=\"search_collections\",\n        ),\n    ]\n\n    # ------------------------------------------------------------------ #\n\n    def search_collections(self) -> Message:\n        # \u2500\u2500 1. Parse the incoming part number \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        raw = self.part_number_message\n        if hasattr(raw, \"text\"):\n            part_number = raw.text.strip()\n        else:\n            part_number = str(raw).strip()\n\n        if not part_number:\n            return Message(text=\"\u26a0\ufe0f  No part number supplied.\")\n\n        # \u2500\u2500 2. Connect to ChromaDB \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        try:\n            port = int(self.chroma_port)\n            client = chromadb.HttpClient(host=self.chroma_host, port=port)\n        except Exception as exc:\n            return Message(text=f\"\u274c  Could not connect to ChromaDB: {exc}\")\n\n        # \u2500\u2500 3. List all collections \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        try:\n            all_collections = client.list_collections()   # returns list[CollectionModel]\n        except Exception as exc:\n            return Message(text=f\"\u274c  Could not list collections: {exc}\")\n\n        if not all_collections:\n            return Message(text=\"\u26a0\ufe0f  No collections found in ChromaDB.\")\n\n        found_in: list[str] = []\n\n        for coll_meta in all_collections:\n            coll_name: str = coll_meta.name\n\n            try:\n                coll = client.get_collection(name=coll_name)\n            except Exception:\n                continue  # skip unreadable collections\n\n            # \u2500\u2500 Strategy 1: match by document ID \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            try:\n                result = coll.get(ids=[part_number], limit=1)\n                if result.get(\"ids\"):\n                    found_in.append(coll_name)\n                    continue\n            except Exception:\n                pass\n\n            # \u2500\u2500 Strategy 2: match via metadata field \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            try:\n                result = coll.get(\n                    where={self.metadata_key: {\"$eq\": part_number}},\n                    limit=1,\n                )\n                if result.get(\"ids\"):\n                    found_in.append(coll_name)\n                    continue\n            except Exception:\n                pass\n\n            # \u2500\u2500 Strategy 3: match inside document text \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            try:\n                result = coll.get(\n                    where_document={\"$contains\": part_number},\n                    limit=1,\n                )\n                if result.get(\"ids\"):\n                    found_in.append(coll_name)\n                    continue\n            except Exception:\n                pass\n\n        # \u2500\u2500 4. Build output \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        if not found_in:\n            return Message(\n                text=f\"\u274c  Part number '{part_number}' was not found in any collection.\"\n            )\n\n        if len(found_in) == 1:\n            return Message(\n                text=f\"\u2705  Part number '{part_number}' \u2192 Model: **{found_in[0]}**\"\n            )\n\n        models_list = \", \".join(found_in)\n        return Message(\n            text=(\n                f\"\u26a0\ufe0f  Part number '{part_number}' was found in multiple collections:\\n\"\n                f\"{models_list}\"\n            )\n        )\n",
                "show": true,
