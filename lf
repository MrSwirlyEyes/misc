from langflow.custom import Component
from langflow.io import MessageInput, Output, StrInput
from langflow.schema.message import Message
import chromadb


class ChromaPartNumberSearch(Component):
    display_name = "Chroma Part Number Search"
    description = "Find the model (collection name) that contains the given part number."
    icon = "database"

    inputs = [
        MessageInput(
            name="part_number_message",
            display_name="Part Number",
            info="Connect Chat Input here.",
        ),
        StrInput(
            name="chroma_host",
            display_name="Chroma Host",
            value="localhost",
            advanced=True,
        ),
        StrInput(
            name="chroma_port",
            display_name="Chroma Port",
            value="8000",
            advanced=True,
        ),
        StrInput(
            name="metadata_key",
            display_name="Part Number Metadata Key",
            value="part_number",
            info="Metadata field name storing part numbers (used as fallback).",
            advanced=True,
        ),
    ]

    outputs = [
        Output(
            display_name="Result",
            name="result_message",
            method="search_collections",
        ),
    ]

    def search_collections(self) -> Message:
        raw = self.part_number_message
        part_number = (raw.text if hasattr(raw, "text") else str(raw)).strip()

        if not part_number:
            return Message(text="No part number supplied.")

        try:
            client = chromadb.HttpClient(
                host=self.chroma_host,
                port=int(self.chroma_port)
            )
        except Exception as exc:
            return Message(text=f"Could not connect to ChromaDB: {exc}")

        try:
            collections = client.list_collections()
        except Exception as exc:
            return Message(text=f"Could not list collections: {exc}")

        if not collections:
            return Message(text="No collections found in ChromaDB.")

        found_in = []

        for coll_meta in collections:
            name = coll_meta.name
            try:
                coll = client.get_collection(name=name)
            except Exception:
                continue

            # Strategy 1: part number stored as document ID
            try:
                if coll.get(ids=[part_number]).get("ids"):
                    found_in.append(name)
                    continue
            except Exception:
                pass

            # Strategy 2: part number stored as metadata field
            try:
                if coll.get(
                    where={self.metadata_key: {"$eq": part_number}}, limit=1
                ).get("ids"):
                    found_in.append(name)
                    continue
            except Exception:
                pass

            # Strategy 3: part number appears in document text
            try:
                if coll.get(
                    where_document={"$contains": part_number}, limit=1
                ).get("ids"):
                    found_in.append(name)
                    continue
            except Exception:
                pass

        if not found_in:
            return Message(text=f"Part number '{part_number}' not found in any collection.")
        if len(found_in) == 1:
            return Message(text=f"Part number '{part_number}' -> Model: {found_in[0]}")
        return Message(text=f"Found in multiple models: {', '.join(found_in)}")
